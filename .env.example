# ROPD environment template.
#
# Copy this file to `.env` and fill in the values you need. The bundled
# training/*.sh wrappers source the repo `.env` automatically (skip with
# ROPD_SKIP_REPO_DOTENV=true).

# --- Datasets / model paths ------------------------------------------------
DATA_ROOT="datasets/unified"
ROPD_TRAIN_TASK="math/dapo-math-17k"
ROPD_VAL_TASK="math_eval/aime24"
ROPD_MODEL_PATH="models/Qwen3-4B"
ROPD_CKPT_DIR="checkpoints/ropd"

# Path to the offline teacher answer index (jsonl) consumed by the
# `offline_index` teacher provider during training. Build it with
# `scripts/build_teacher_index.py` (see README "Teacher index").
ROPD_TEACHER_INDEX_PATH="datasets/unified/math/dapo-math-17k/artifacts/teacher_index/shared-teacher-index.jsonl"

# --- Local vLLM judge -----------------------------------------------------
# Started by `bash training/launch_judge_vllm.sh`. Set the model path before
# running it.
ROPD_JUDGE_MODEL_PATH=""
ROPD_JUDGE_SERVED_MODEL_NAME="Qwen3-30B-A3B-Instruct-2507"
ROPD_VLLM_BASE_URL="http://127.0.0.1:18080/v1"
ROPD_VLLM_MODEL="Qwen3-30B-A3B-Instruct-2507"
ROPD_VLLM_API_KEY="EMPTY"

# --- Judge provider -----------------------------------------------------------
# ROPD_JUDGE_PROFILE selects which profile in judge_providers.yaml is used for
# the rubricator and verifier. Two profiles are available:
#   openai_default  - OpenAI Responses API (default; OpenAI direct only)
#   openai_chat     - Standard chat/completions (DeepSeek, Azure, LLM gateways)
# ROPD_JUDGE_PROFILE="openai_chat"
OPENAI_API_KEY=""
OPENAI_BASE_URL=""

# Models for each judge role (all default to gpt-5.2-chat-latest if unset).
# ROPD_TEACHER_MODEL="deepseek-chat"
# ROPD_RUBRICATOR_MODEL="deepseek-chat"
# ROPD_VERIFIER_MODEL="deepseek-chat"

# If your provider does not support reasoning_effort (e.g. DeepSeek), set
# these to empty string to disable the parameter entirely.
# ROPD_RUBRICATOR_REASONING_EFFORT=""
# ROPD_VERIFIER_REASONING_EFFORT=""

# Number of teacher reference answers per prompt (default 4; use 1 for debug).
# ROPD_TEACHER_ANSWER_COUNT=1

# --- Logging --------------------------------------------------------------
# WANDB_ENTITY=""
# WANDB_PROJECT="ROPD"
# WANDB_MODE="online"

# --- Naming --------------------------------------------------------------
EXPERIMENT="ropd"
